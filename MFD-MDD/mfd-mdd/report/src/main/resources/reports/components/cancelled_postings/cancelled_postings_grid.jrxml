	</parameter>
	<parameter name="SQL_DATE_TO" class="java.sql.Date" isForPrompting="false" evaluationTime="Late">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf($P{DATE_TO})]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT poc.name_last as client_last_name,
	   poc.name_first as client_first_name,
       p.name as office_name,
       pl.name as location_name,
       GROUP_CONCAT(DISTINCT DATE_FORMAT(jd.date, '%m/%d/%y') ORDER BY jd.date SEPARATOR '\n') as cancelled_dates,
       prc.name_last as professional_last_name,
       prc.name_first as professional_first_name,
	   GROUP_CONCAT(DISTINCT sc.name ORDER BY sc.name SEPARATOR '\n ') as position,
       jp.start_date as posting_start_date,
       jpa.modified_date as cancel_submitted_date
 FROM job_posting_applications jpa JOIN job_postings jp ON (jpa.fk_job_posting_id = jp.id)
							 JOIN practice_locations pl ON (jp.fk_practice_location_id = pl.id)
							 JOIN practices p ON (pl.fk_practice_id = p.owner_id)
							 JOIN users po ON (p.owner_id  = po.id)
							 JOIN contacts poc ON (po.fk_contact_id  = poc.id)
							 JOIN users pr ON (jpa.fk_professional_id  = pr.id)
							 JOIN contacts prc ON (pr.fk_contact_id  = prc.id)
							 JOIN temporary_job_posting_application_job_days tjpajd ON (jpa.id = tjpajd.fk_application_id)
							 JOIN job_days jd ON (tjpajd.fk_job_day_id = jd.id AND jd.date >= DATE(jpa.modified_date))
                             JOIN job_posting_sub_categories jpsc ON (jp.id = jpsc.fk_job_posting_id)
                             JOIN sub_categories sc ON (jpsc.fk_sub_category_id = sc.id)
  WHERE jpa.status IN ('ACCEPTED_CANCELLED_DURING_JOB_POSTING_CANCEL', 'CANCELLED') AND jpa.modified_date  >= $P{SQL_DATE_FROM} AND jpa.modified_date  < DATE_ADD($P{SQL_DATE_TO}, INTERVAL 1 DAY)
GROUP BY jpa.id]]>
	</queryString>
