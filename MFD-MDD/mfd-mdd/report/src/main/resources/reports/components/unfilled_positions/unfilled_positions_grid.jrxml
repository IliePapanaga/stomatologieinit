	</parameter>
	<parameter name="IS_ON_JASPER_REPORT_SERVER" class="java.lang.Boolean">
		<defaultValueExpression><![CDATA[java.lang.Boolean.FALSE]]></defaultValueExpression>
	</parameter>
	<parameter name="SQL_DATE_FROM" class="java.sql.Date" isForPrompting="false" evaluationTime="Late">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf($P{DATE_FROM})]]></defaultValueExpression>
	</parameter>
	<parameter name="SQL_DATE_TO" class="java.sql.Date" isForPrompting="false" evaluationTime="Late">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf($P{DATE_TO})]]></defaultValueExpression>
	</parameter>
	<parameter name="POSITION_TYPE" class="java.lang.String"/>
	<parameter name="REQUIRED_SUBCATEGORY" class="java.lang.String"/>
	<parameter name="MIN_UNFILLED_DAYS" class="java.lang.Integer"/>
	<parameter name="MAX_UNFILLED_DAYS" class="java.lang.Integer"/>
	<parameter name="LATITUDE" class="java.lang.Double"/>
	<parameter name="LONGITUDE" class="java.lang.Double"/>
	<parameter name="RADIUS" class="java.lang.Double"/>
	<queryString>
		<![CDATA[SELECT * FROM (SELECT jp.id,
					  sc.name,
					  jp.job_posting_type,
                      jp.created_date,
					  pl.name location_name,
                      p.name practice_name,
                      a.city,
                      a.state,
                      a.latitude,
                      a.longitude
FROM job_postings jp JOIN job_posting_sub_categories jpsc ON (jp.id = jpsc.fk_job_posting_id)
					 JOIN sub_categories sc ON (jpsc.fk_sub_category_id = sc.id)
                     JOIN practice_locations pl ON (jp.fk_practice_location_id = pl.id)
                     JOIN practices p ON (pl.fk_practice_id = p.owner_id)
                     JOIN contacts c ON (pl.fk_contact_id = c.id)
                     JOIN addresses a ON (c.fk_address_id = a.id)
                     WHERE $P{REQUIRED_SUBCATEGORY} IN (jpsc.fk_sub_category_id, 'ANY')) T
WHERE EXISTS (SELECT 1 FROM job_postings jp 
			  WHERE jp.id = T.id AND
					jp.created_date >= $P{SQL_DATE_FROM} AND jp.created_date < DATE_ADD($P{SQL_DATE_TO}, INTERVAL 1 DAY) AND
				    $P{POSITION_TYPE} IN (jp.job_posting_type, 'ANY'))
	   AND (T.job_posting_type = 'TEMPORARY_JOB_POSTING' OR DATEDIFF(CURRENT_DATE(), T.created_date) BETWEEN $P{MIN_UNFILLED_DAYS} AND $P{MAX_UNFILLED_DAYS})
       AND (T.job_posting_type = 'PERMANENT_JOB_POSTING' OR (SELECT SUM(1) FROM job_days jd WHERE jd.fk_posting_id = T.id and jd.excluded = 0 AND jd.status = 'NEW') BETWEEN $P{MIN_UNFILLED_DAYS} AND $P{MAX_UNFILLED_DAYS})
	   AND              
		  ((T.longitude BETWEEN $P{LONGITUDE} - $P{RADIUS}/abs(COS($P{LATITUDE} * pi()/180)) * 69 AND $P{LONGITUDE} + $P{RADIUS}/abs(COS($P{LATITUDE} * pi()/180)) AND
           T.latitude BETWEEN $P{LATITUDE} - $P{RADIUS}/69 AND $P{LATITUDE} + $P{RADIUS}/69) AND

          ($P{RADIUS} >= (3956 * 2 * ASIN(SQRT(POWER(SIN(($P{LATITUDE} - T.latitude) * pi()/180/2),2) + COS($P{LATITUDE} * pi()/180) * COS(T.latitude*pi()/180)*POWER(SIN(($P{LONGITUDE} - T.longitude)*pi()/180/2),2))))))]]>
	</queryString>
	<field name="id" class="java.lang.String"/>
	<field name="name" class="java.lang.String"/>
	<field name="job_posting_type" class="java.lang.String"/>
	<field name="created_date" class="java.sql.Timestamp"/>
	<field name="location_name" class="java.lang.String"/>
	<field name="practice_name" class="java.lang.String"/>
	<field name="city" class="java.lang.String"/>
	<field name="state" class="java.lang.String"/>
	<field name="latitude" class="java.lang.Double"/>
	<field name="longitude" class="java.lang.Double"/>
	<variable name="SQL_DATE_TO" class="java.sql.Date">
		<variableExpression><![CDATA[java.sql.Date.valueOf($P{DATE_TO})]]></variableExpression>
	</variable>
	<variable name="SQL_DATE_FROM" class="java.sql.Date">
		<variableExpression><![CDATA[java.sql.Date.valueOf($P{DATE_FROM})]]></variableExpression>
	</variable>
