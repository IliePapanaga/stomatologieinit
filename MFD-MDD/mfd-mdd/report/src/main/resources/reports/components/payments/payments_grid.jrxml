		<defaultValueExpression><![CDATA[java.sql.Date.valueOf($P{DATE_FROM})]]></defaultValueExpression>
	</parameter>
	<parameter name="SQL_DATE_TO" class="java.sql.Date" isForPrompting="false" evaluationTime="Late">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf($P{DATE_TO})]]></defaultValueExpression>
	</parameter>
	<parameter name="DATE_GROUP_BY" class="java.lang.String" evaluationTime="Early">
		<parameterDescription><![CDATA[]]></parameterDescription>
	</parameter>
	<queryString>
 		<![CDATA[SELECT CASE WHEN $P{DATE_GROUP_BY} = 'DAY' THEN DATE_FORMAT(p.created_date, '%Y-%d-%m')
			WHEN $P{DATE_GROUP_BY} = 'WEEK' THEN CONCAT(DATE_FORMAT(ADDDATE(p.created_date, 1-DAYOFWEEK(p.created_date)), '%Y-%d-%m'),'/',DATE_FORMAT(ADDDATE(p.created_date, 7-DAYOFWEEK(p.created_date)), '%Y-%d-%m'))
		    WHEN $P{DATE_GROUP_BY} = 'MONTH' THEN DATE_FORMAT(p.created_date, '%Y-%m')
            WHEN $P{DATE_GROUP_BY} = 'YEAR' THEN DATE_FORMAT(p.created_date, '%Y')
			WHEN $P{DATE_GROUP_BY} = 'NO_GROUP' THEN p.created_date
	   END AS PERIOD,
SUM(CASE WHEN p.payment_status IN ('PAID') THEN p.amount ELSE 0 END) AS PAID_AMOUNT,
SUM(CASE WHEN p.payment_status IN ('FAILED_FINAL') THEN p.amount ELSE 0 END) AS DELINQUENT_AMOUNT
FROM payments p WHERE p.created_date >= $P{SQL_DATE_FROM} AND p.created_date <  DATE_ADD($P{SQL_DATE_TO}, INTERVAL 1 DAY)
GROUP BY CASE 	WHEN $P{DATE_GROUP_BY} = 'DAY' THEN DATE_FORMAT(p.created_date, '%Y-%d-%m')
				WHEN $P{DATE_GROUP_BY} = 'WEEK' THEN CONCAT(DATE_FORMAT(ADDDATE(p.created_date, 1-DAYOFWEEK(p.created_date)), '%Y-%d-%m'),'/',DATE_FORMAT(ADDDATE(p.created_date, 7-DAYOFWEEK(p.created_date)), '%Y-%d-%m'))
				WHEN $P{DATE_GROUP_BY} = 'MONTH' THEN DATE_FORMAT(p.created_date, '%Y-%m')
				WHEN $P{DATE_GROUP_BY} = 'YEAR' THEN DATE_FORMAT(p.created_date, '%Y')
				WHEN $P{DATE_GROUP_BY} = 'NO_GROUP' THEN p.created_date
		 END]]>
	</queryString>
	<field name="PERIOD" class="java.lang.String"/>
	<field name="PAID_AMOUNT" class="java.math.BigDecimal"/>
	<field name="DELINQUENT_AMOUNT" class="java.math.BigDecimal"/>
	<variable name="SQL_DATE_TO" class="java.sql.Date">
		<variableExpression><![CDATA[java.sql.Date.valueOf($P{DATE_TO})]]></variableExpression>
	</variable>
	<variable name="SQL_DATE_FROM" class="java.sql.Date">
		<variableExpression><![CDATA[java.sql.Date.valueOf($P{DATE_FROM})]]></variableExpression>
	</variable>
