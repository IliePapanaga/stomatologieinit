	<parameter name="SQL_DATE_FROM" class="java.sql.Date" isForPrompting="false" evaluationTime="Late">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf($P{DATE_FROM})]]></defaultValueExpression>
	</parameter>
	<parameter name="SQL_DATE_TO" class="java.sql.Date" isForPrompting="false" evaluationTime="Late">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf($P{DATE_TO})]]></defaultValueExpression>
	</parameter>
	<parameter name="POSITION_TYPE" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT 	sc.name,
		COUNT(jpsc.fk_job_posting_id) AS NR_OF_POSITIONS,
        (SELECT COUNT(jpsc.fk_job_posting_id)
        FROM sub_categories sc  JOIN job_posting_sub_categories jpsc ON (sc.id = jpsc.fk_sub_category_id)
						JOIN job_postings jp ON (jpsc.fk_job_posting_id = jp.id)
		WHERE jp.created_date  >= $P{SQL_DATE_FROM} AND jp.created_date  < DATE_ADD($P{SQL_DATE_TO}, INTERVAL 1 DAY)  AND $P{POSITION_TYPE} IN (jp.job_posting_type, 'ANY') ) AS TOTAL_NUMBER_OF_POSITIONS
FROM sub_categories sc  JOIN job_posting_sub_categories jpsc ON (sc.id = jpsc.fk_sub_category_id)
						JOIN job_postings jp ON (jpsc.fk_job_posting_id = jp.id)
WHERE jp.created_date  >= $P{SQL_DATE_FROM} AND jp.created_date  < DATE_ADD($P{SQL_DATE_TO}, INTERVAL 1 DAY)  AND $P{POSITION_TYPE} IN (jp.job_posting_type, 'ANY')
GROUP BY sc.name]]>
	</queryString>
	<field name="NAME" class="java.lang.String"/>
	<field name="NR_OF_POSITIONS" class="java.lang.Long"/>
	<field name="TOTAL_NUMBER_OF_POSITIONS" class="java.lang.Long"/>
	<variable name="SQL_DATE_TO" class="java.sql.Date">
