	<field name="DATE_FORMAT(STR_TO_DATE(CC.CC_EXP,&apos;%m%y&apos;), &apos;%m %Y&apos;)" class="java.lang.String"/>
	<field name="CC_NUMBER" class="java.lang.String"/>
