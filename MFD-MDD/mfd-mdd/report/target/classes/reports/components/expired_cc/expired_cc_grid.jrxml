	<queryString>
		<![CDATA[SELECT  c.name_last,
		c.name_first,
        c.email,
        c.phone,
        a.street,
        a.city,
        a.state,
        a.zip_code,
        u.last_activity_date,
        DATE_FORMAT(STR_TO_DATE(cc.cc_exp,'%m%y'), '%m %Y'),
        cc.cc_number
FROM users u JOIN contacts c ON (u.fk_contact_id = c.id)
			 JOIN addresses a ON (a.id = c.fk_address_id)
             JOIN payment_methods p ON (u.id = p.fk_practice_id)
             JOIN payment_methods_card cc ON (p.id = cc.id)
WHERE u.user_type = 'PRACTICE_OWNER' AND STR_TO_DATE(cc.cc_exp,'%m%y') < CURDATE()]]>
	</queryString>
	<field name="NAME_LAST" class="java.lang.String"/>
	<field name="NAME_FIRST" class="java.lang.String"/>
