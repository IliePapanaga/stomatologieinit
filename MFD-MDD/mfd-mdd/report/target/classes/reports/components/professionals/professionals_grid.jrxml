	<parameter name="SQL_DATE_TO" class="java.sql.Date" isForPrompting="false" evaluationTime="Late">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf($P{DATE_TO})]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT c.name_last, c.name_first, u.status, c.email, c.phone, a.street, a.city, a.state, a.zip_code, u.last_activity_date
					FROM users u JOIN contacts c ON (u.fk_contact_id = c.id)
								 JOIN addresses a ON (a.id = c.fk_address_id)
					WHERE u.user_type = 'PROFESSIONAL' AND u.last_activity_date >= $P{SQL_DATE_FROM} AND u.last_activity_date < DATE_ADD($P{SQL_DATE_TO}, INTERVAL 1 DAY)]]>
	</queryString>
	<field name="NAME_LAST" class="java.lang.String"/>
	<field name="NAME_FIRST" class="java.lang.String"/>
