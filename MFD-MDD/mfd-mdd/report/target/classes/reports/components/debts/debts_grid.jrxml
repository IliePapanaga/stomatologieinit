	</parameter>
	<queryString>
		<![CDATA[SELECT  c.name_last,
		c.name_first,
        c.email,
        c.phone,
        a.street,
        a.city,
        a.state,
        a.zip_code,
        u.last_activity_date,
        SUM(CASE WHEN DATEDIFF(CURDATE(), p.created_date) BETWEEN 1 AND 30 THEN p.amount ELSE 0 END) AS FIRST_AGE_DEBT,
        SUM(CASE WHEN DATEDIFF(CURDATE(), p.created_date) BETWEEN 31 AND 60 THEN p.amount ELSE 0 END) AS SECOND_AGE_DEBT,
        SUM(CASE WHEN DATEDIFF(CURDATE(), p.created_date) BETWEEN 61 AND 90 THEN p.amount ELSE 0 END) AS THIRD_AGE_DEBT,
        SUM(CASE WHEN DATEDIFF(CURDATE(), p.created_date) > 90 THEN p.amount ELSE 0 END) AS FOURTH_AGE_DEBT,
        SUM(p.amount) AS TOTAL_DEBT
FROM users u JOIN contacts c ON (u.fk_contact_id = c.id)
			 JOIN addresses a ON (a.id = c.fk_address_id)
             JOIN payments p ON (u.id = p.fk_practice_id)
WHERE u.user_type = 'PRACTICE_OWNER' AND p.payment_status IN ('FAILED_FINAL')
GROUP BY u.id]]>
	</queryString>
